# Live market momentum (optional).
# Without this key the app falls back to illustrative placeholder momentum.
# Free tier: https://finnhub.io/  — copy this file to `.env.local` and add your key.
VITE_FINNHUB_KEY=

# Server-side key for the daily node-sizing cron (/api/sizes). Set this in the
# Vercel project's Environment Variables. Falls back to VITE_FINNHUB_KEY if unset.
# Without it, node sizes fall back to capital-flow volume (no "Sizes updated" badge).
FINNHUB_KEY=
